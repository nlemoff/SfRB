{
  "title": "SfRB Document",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "default": 1,
      "type": "number",
      "const": 1
    },
    "metadata": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "locale": {
          "default": "en-US",
          "type": "string",
          "minLength": 2
        }
      },
      "required": [
        "title",
        "locale"
      ],
      "additionalProperties": false
    },
    "semantic": {
      "type": "object",
      "properties": {
        "sections": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "blockIds": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
                }
              }
            },
            "required": [
              "id",
              "title",
              "blockIds"
            ],
            "additionalProperties": false
          }
        },
        "blocks": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "heading",
                  "paragraph",
                  "bullet",
                  "fact"
                ]
              },
              "text": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "id",
              "kind",
              "text"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "sections",
        "blocks"
      ],
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "properties": {
        "pages": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
              },
              "size": {
                "type": "object",
                "properties": {
                  "width": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "height": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "required": [
                  "width",
                  "height"
                ],
                "additionalProperties": false
              },
              "margin": {
                "type": "object",
                "properties": {
                  "top": {
                    "type": "number",
                    "minimum": 0
                  },
                  "right": {
                    "type": "number",
                    "minimum": 0
                  },
                  "bottom": {
                    "type": "number",
                    "minimum": 0
                  },
                  "left": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "required": [
                  "top",
                  "right",
                  "bottom",
                  "left"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "id",
              "size",
              "margin"
            ],
            "additionalProperties": false
          }
        },
        "frames": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
              },
              "pageId": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
              },
              "blockId": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
              },
              "box": {
                "type": "object",
                "properties": {
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  },
                  "width": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "height": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "required": [
                  "x",
                  "y",
                  "width",
                  "height"
                ],
                "additionalProperties": false
              },
              "zIndex": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "id",
              "pageId",
              "blockId",
              "box",
              "zIndex"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "pages",
        "frames"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "metadata",
    "semantic",
    "layout"
  ],
  "additionalProperties": false
}
