# SfRB local AI consultant configuration
# Copy to .env for local development, or export these vars in your shell before `sfrb open`.
# Never commit real API keys.

# Default provider for new SfRB workspaces.
# Used when sfrb.config.json has ai.provider = "deepseek".
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: override the default DeepSeek layout-consultant model.
# SfRB defaults to deepseek-v4-flash.
SFRB_CONSULTANT_DEEPSEEK_MODEL=deepseek-v4-flash

# Optional: use a local/stub DeepSeek-compatible endpoint for tests or development.
# SFRB_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Legacy/alternate providers are still supported when configured explicitly.
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
