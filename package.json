{
  "name": "sfrb",
  "version": "0.1.0",
  "description": "Straightforward Resume Builder CLI",
  "license": "Apache-2.0",
  "type": "commonjs",
  "bin": {
    "sfrb": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "web/",
    "schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-bridge-runtime.mjs",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:web": "vitest run tests/web",
    "test:setup:browsers": "playwright install chromium",
    "verify:package": "node scripts/verify-package-install.mjs",
    "verify:smoke": "npm run build && node scripts/verify-s04-editor-smoke.mjs && node scripts/verify-s05-layout-consultant.mjs && node scripts/verify-cli-edit-smoke.mjs && node scripts/verify-tile-engine-smoke.mjs && node scripts/verify-freeform-smoke.mjs && node scripts/verify-mode-reconciliation-smoke.mjs",
    "schema:generate": "npm run build && node scripts/generate-schema.mjs",
    "schema:check": "npm run build && node scripts/check-schema.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "duplication": "jscpd",
    "docs": "typedoc",
    "check:tech-debt": "node scripts/check-tech-debt.mjs",
    "check:large-files": "node scripts/check-large-files.mjs",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "commander": "^15.0.0",
    "enquirer": "^2.4.1",
    "playwright": "^1.61.0",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "knip": "^6.20.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4"
  }
}
