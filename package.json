{
  "name": "sfrb",
  "version": "0.1.0",
  "description": "Straightforward Resume Builder CLI",
  "private": true,
  "bin": {
    "sfrb": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
